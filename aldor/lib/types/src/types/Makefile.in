# ..From autoconf
@SET_MAKE@
VPATH = @srcdir@

# For AM_V_*
AM_DEFAULT_VERBOSITY = @AM_DEFAULT_VERBOSITY@

builddir	:= @builddir@
abs_builddir	:= @abs_builddir@
top_builddir	:= @top_builddir@
abs_top_builddir:= @abs_top_builddir@
srcdir		:= @srcdir@
abs_srcdir	:= @abs_srcdir@
top_srcdir	:= @top_srcdir@
abs_top_srcdir	:= @abs_top_srcdir@
subdir		:= $(subst $(abs_top_builddir)/,,$(abs_builddir))

# Build starts here..

library=\
	tp_annotated	\
	tp_counter	\
	tp_env		\
	tp_expr		\
	tp_infer	\
	tp_listset	\
	tp_subst	\
	tp_sx		\
	tp_test		\
	tp_tposs	\
	tp_typeterm	\
	tp_unify

#	tp_simple	

include $(abs_top_srcdir)/lib/types/src/common.mk

