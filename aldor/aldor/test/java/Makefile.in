@SET_MAKE@
AM_DEFAULT_VERBOSITY = @AM_DEFAULT_VERBOSITY@
VPATH = @srcdir@

builddir	:= @builddir@
testdir		:= @top_builddir@/aldor/test
top_builddir	:= @top_builddir@

abs_builddir	:= @abs_builddir@
top_builddir	:= @top_builddir@
abs_top_builddir:= @abs_top_builddir@
srcdir		:= @srcdir@
abs_srcdir	:= @abs_srcdir@
top_srcdir	:= @top_srcdir@
abs_top_srcdir	:= @abs_top_srcdir@
abs_libdir	:= $(abs_builddir)
subdir		:= $(subst $(abs_top_builddir)/,,$(abs_builddir))
top_srcdir	:= @top_srcdir@

utils := tassert

jtests := simple_j run_j
jruntests := jimport jimport_opt jimp0 jimp1 jlist jexport jexport1 jexport2 jexn jthrow jenvname
junittests := JExportTest JThrowTest

simple_j_AXLFLAGS=-Q2
jimport_opt_AXLFLAGS=-Q9 -Qinline-all

jexport_extjava := aldor.stuff.Foo aldor.stuff.Bar
jthrow_extjava  := aldor.stuff.ExnThrow
jenvname_extjava := aldor.stuff.Env
jlist_extjava   := aldor.stuff.Singleton
jexn_srcjava    := aldor.test.ExceptionExample
JExportTest_classes := aldorcode.jexport
JThrowTest_classes  := aldorcode.jthrow

include $(top_srcdir)/aldor/test/test-common.mk
